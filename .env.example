# ──────────────────────────────────────────────
# klovis-agent – Environment variables
# Copy this file:  cp .env.example .env
# Then fill in your values.
# ──────────────────────────────────────────────

# ── LLM (required) ───────────────────────────
AGENT_LLM__API_KEY=
AGENT_LLM__DEFAULT_MODEL=gpt-4o
AGENT_LLM__BASE_URL=https://api.openai.com/v1
AGENT_LLM__MAX_TOKENS=4096
AGENT_LLM__TEMPERATURE=0.2

# ── Embeddings (optional – falls back to LLM config when empty) ──
AGENT_EMBEDDING__API_KEY=
AGENT_EMBEDDING__BASE_URL=
AGENT_EMBEDDING__MODEL=BGE-M3

# ── Agent ─────────────────────────────────────
AGENT_MAX_ITERATIONS=25
AGENT_DATA_DIR=

# ── Sandbox ───────────────────────────────────
AGENT_SANDBOX__BACKEND=local
